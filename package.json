    "@types/multer": "^2.1.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "gsap": "^3.12.5",
    "jsonwebtoken": "^9.0.3",
    "lenis": "^1.1.20",
