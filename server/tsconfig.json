{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "..",
    "noEmit": false,
    "declaration": false,
    "isolatedModules": false,
    "allowImportingTsExtensions": false
  },
  "include": ["src/**/*.ts", "../data/**/*.ts"],
  "exclude": ["../node_modules"]
}
